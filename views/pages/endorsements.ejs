        </div>
        <div class="d360-strip-stats">
          <div><div class="d360-strip-stat-num">22</div><div class="d360-strip-stat-label">This month</div></div>
          <div><div class="d360-strip-stat-num">62%</div><div class="d360-strip-stat-label">Auto</div></div>
          <div><div class="d360-strip-stat-num">1.8d</div><div class="d360-strip-stat-label">Avg time</div></div>
        </div>
      </div>

      <div class="tabs">
        <div class="tab active">All <span class="tab-count">22</span></div>
        <div class="tab">Pending <span class="tab-count">4</span></div>
        <div class="tab">In review <span class="tab-count">2</span></div>
        <div class="tab">Approved <span class="tab-count">14</span></div>
        <div class="tab">Declined <span class="tab-count">2</span></div>
