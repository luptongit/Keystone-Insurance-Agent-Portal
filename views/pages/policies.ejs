<%- include('../partials/head', { pageCSS: 'policies' }) %>
<div class="app">
  <%- include('../partials/sidebar') %>

  <main class="main">
    <%- include('../partials/topbar', {
      breadcrumb: [
        { label: 'Service' },
        { label: 'Policies' }
      ],
      topbarActions: `
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
          Filter
        </button>
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          Export
        </button>
      `
    }) %>

    <div class="content">

      <div class="page-header">
        <div>
          <div class="greeting-eyebrow">Service · April 2026</div>
          <h1 class="greeting-title">Policy <em>management</em></h1>
          <div class="greeting-sub">287 active policies — 4 pending endorsements, 2 claims open.</div>
        </div>
      </div>

      <div class="kpi-row cols-4">
        <div class="kpi">
          <div class="kpi-label">Active policies</div>
          <div class="kpi-value">287</div>
          <div class="kpi-meta"><span class="kpi-delta up">↑ 8</span><span class="kpi-delta-label">new this month</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Pending endorsements</div>
          <div class="kpi-value"><%= (groups.pending_endorsements || []).length %></div>
          <div class="kpi-meta"><span class="kpi-delta-label">avg 1.8d turnaround</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Open claims</div>
          <div class="kpi-value"><%= (groups.active_claims || []).length %></div>
          <div class="kpi-meta"><span class="kpi-delta-label">1 auto · 1 property</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-d360-flag"><span class="d360-pill">D360</span></div>
          <div class="kpi-label">Coverage gap alerts</div>
          <div class="kpi-value">6</div>
          <div class="kpi-meta"><span class="kpi-delta-label">policies below recommended limits</span></div>
        </div>
      </div>

      <div class="d360-strip">
        <div class="d360-strip-mark"><div class="d360-strip-mark-inner"></div></div>
        <div class="d360-strip-text">
          <div class="d360-strip-eyebrow">Powered by Data 360</div>
          <div class="d360-strip-title">Coverage adequacy scoring compares policy limits against replacement costs, liability exposure, and peer benchmarks to flag under-insured risks.</div>
          <div class="d360-strip-sub">Policies with coverage gaps have 2.4× higher E&O exposure and 18% lower retention rates.</div>
        </div>
        <div class="d360-strip-stats">
          <div><div class="d360-strip-stat-num">287</div><div class="d360-strip-stat-label">Analyzed</div></div>
          <div><div class="d360-strip-stat-num">6</div><div class="d360-strip-stat-label">Gaps</div></div>
          <div><div class="d360-strip-stat-num">live</div><div class="d360-strip-stat-label">Updated</div></div>
        </div>
      </div>

      <div data-filter-scope>
      <div class="tabs">
        <div class="tab active" data-filter="all">All active <span class="tab-count">287</span></div>
        <div class="tab" data-filter="pending_endorsements">Pending <span class="tab-count"><%= (groups.pending_endorsements || []).length %></span></div>
        <div class="tab" data-filter="recently_issued">Recently issued <span class="tab-count"><%= (groups.recently_issued || []).length %></span></div>
        <div class="tab" data-filter="cancelled">Cancelled <span class="tab-count">3</span></div>
      </div>

      <div class="list-search">
        <svg class="list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        <input class="list-search-input" placeholder="Search policies..." data-search-scope=".pol-table" />
      </div>

      <div class="pol-layout">

        <div class="pol-table">

          <div class="pol-table-header">
            <span>Insured</span>
            <span>Policy #</span>
            <span>Line</span>
            <span>Premium</span>
            <span>Effective</span>
            <span>Expires</span>
            <span>Status</span>
            <span></span>
          </div>

          <%
            const polGroups = [
              { key: 'recently_issued', label: 'Recently issued', sub: (groups.recently_issued || []).length + ' policies this month', href: '/customers' },
              { key: 'pending_endorsements', label: 'Pending endorsements', sub: (groups.pending_endorsements || []).length + ' policies with open changes', href: '/endorsements' },
              { key: 'active_claims', label: 'Active claims', sub: (groups.active_claims || []).length + ' policies with open claims', href: '/claims' },
            ];
          %>

          <% polGroups.forEach(g => { %>
            <% const rows = groups[g.key] || []; %>
            <% if (rows.length) { %>
              <div class="pol-group" data-filter-group>
                <div class="pol-group-label"><%= g.label %> <span class="pol-group-count"><%= g.sub %></span></div>

                <% rows.forEach(row => { %>
                  <a class="pol-row<%= row.row_style ? ' ' + row.row_style : '' %>" href="<%= row.row_style === 'pending' ? '/endorsements' : row.row_style === 'claim' ? '/claims' : '/customers/' + row.slug %>" data-filter-value="<%= row.group_key %>" data-search-text="<%= row.customer_name %> <%= row.policy_number %> <%= row.detail %>">
                    <div class="pol-row-name">
                      <div class="pol-row-customer"><%= row.customer_name %></div>
                      <div class="pol-row-detail"><%= row.detail %></div>
                    </div>
                    <div class="pol-row-num"><%= row.policy_number %></div>
                    <div>
                      <% row.lines.forEach(line => { %>
                        <span class="pol-line <%= line %>"><%= line.charAt(0).toUpperCase() + line.slice(1) %></span>
                      <% }) %>
                    </div>
                    <div class="pol-row-premium">$<%= row.premium.toLocaleString() %>/yr</div>
                    <div class="pol-row-date"><%= row.effective_date %></div>
                    <div class="pol-row-date"><%= row.expiration_date %></div>
                    <div><span class="pol-status-badge <%= row.status %>"><%= row.status.charAt(0).toUpperCase() + row.status.slice(1) %></span></div>
                    <div class="pol-row-action"><button class="btn"><%= row.row_style === 'pending' || row.row_style === 'claim' ? 'Review' : 'View' %></button></div>
                  </a>
                <% }) %>
              </div>
            <% } %>
          <% }) %>

        </div>

        <!-- POLICY INTELLIGENCE SIDEBAR -->
        <div class="pol-sidebar">

          <div class="panel">
            <div class="panel-header">
              <div>
                <span class="panel-title">Coverage intelligence</span>
              </div>
              <span class="d360-pill">Data 360</span>
            </div>

            <div class="intel-item">
              <div class="intel-icon warn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>6 policies have coverage gaps.</strong> Most common: dwelling limits 15%+ below replacement cost estimates. Ramirez and Patel households are the highest-risk.</div>
                <div class="intel-meta">Coverage adequacy model · updated today</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Henderson teen driver add</strong> has been pending UW review for 3 days. Similar endorsements average 1.8 days — consider following up with underwriting.</div>
                <div class="intel-meta">Processing velocity · peer benchmark</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong><%= (groups.recently_issued || []).length %> new policies bound this month</strong> — $14.2K in new annual premium. Reeves bundle was your largest new-to-book write of the quarter.</div>
                <div class="intel-meta">Production tracking · MTD</div>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">
              <span class="panel-title">Policies by status</span>
            </div>
            <div style="padding: 14px 20px;">
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Active</span><span class="benchmark-percentile">281</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 100%;"></div></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Pending endorsement</span><span class="benchmark-percentile middle"><%= (groups.pending_endorsements || []).length %></span></div>
                <div class="benchmark-bar"><div class="benchmark-fill middle" style="width: 5%;"></div></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Active claim</span><span class="benchmark-percentile middle"><%= (groups.active_claims || []).length %></span></div>
                <div class="benchmark-bar"><div class="benchmark-fill middle" style="width: 3%;"></div></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0; border-bottom: none;">
                <div class="benchmark-head"><span class="benchmark-label">Cancelled (YTD)</span><span class="benchmark-percentile">3</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 4%;background: var(--red);"></div></div>
              </div>
            </div>
          </div>

        </div>

      </div>
      </div>

      <div class="content-footer">
        <div>Keystone Enterprise · Build 4.2.118</div>
        <div>SOC 2 Type II · Last sync 9:42 AM CT</div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
