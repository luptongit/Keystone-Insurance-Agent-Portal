            <a class="pipeline-card" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Martinez Auto Group</span>
                <span class="pipeline-card-age">18d</span>
              </div>
              <div class="pipeline-card-detail">Commercial fleet · 14 vehicles · multi-location · awaiting loss runs from prior carrier</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line commercial">Commercial</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$42,600/yr</span>
                  <span class="deal-score high">76</span>
                </div>
              </div>
            </a>

            <a class="pipeline-card at-risk" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Chen, L.</span>
                <span class="pipeline-card-age">22d</span>
              </div>
              <div class="pipeline-card-detail">Investment property package · duplex · stalled on price — competing Allstate quote received</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line home">Home</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$3,200/yr</span>
                  <span class="deal-score low">62</span>
                </div>
              </div>
              <div class="at-risk-flag">At risk · stalled 8 days</div>
            </a>
          </div>

          <!-- WON -->
          <div class="pipeline-col won">
            <div class="pipeline-col-header">
              <div class="pipeline-col-header-top">
                <span class="pipeline-col-name">Won</span>
                <span class="pipeline-col-count">1</span>
              </div>
              <div class="pipeline-col-total">$3,480/yr · April</div>
            </div>

            <a class="pipeline-card won" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Reeves household</span>
                <span class="pipeline-card-age">Bound</span>
              </div>
              <div class="pipeline-card-detail">Auto + home bundle · new-to-book · referred by Donovan</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line bundle">Bundle</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$3,480/yr</span>
                  <span class="deal-score high">94</span>
                </div>
              </div>
