<%- include('../partials/head', { pageCSS: 'sales-pipeline' }) %>
<div class="app">
  <%- include('../partials/sidebar') %>

  <main class="main">
    <%- include('../partials/topbar', {
      breadcrumb: [
        { label: 'Sell' },
        { label: 'Sales pipeline' }
      ],
      topbarActions: `
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
          Filter
        </button>
        <a class="btn btn-primary" href="/quote/new">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>
          New quote
        </a>
      `
    }) %>

    <div class="content">

      <div class="page-header">
        <div>
          <div class="greeting-eyebrow">Pipeline · April 2026</div>
          <h1 class="greeting-title">Sales <em>pipeline</em></h1>
          <div class="greeting-sub">12 active deals across 5 stages — $312K total, $148K weighted forecast.</div>
        </div>
      </div>

      <div class="kpi-row cols-4">
        <div class="kpi">
          <div class="kpi-label">Active pipeline</div>
          <div class="kpi-value">$312<span class="kpi-value-suffix">K</span></div>
          <div class="kpi-meta"><span class="kpi-delta-label">12 deals · 6 lines</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-d360-flag"><span class="d360-pill">Predicted</span></div>
          <div class="kpi-label">Weighted forecast</div>
          <div class="kpi-value">$148<span class="kpi-value-suffix">K</span></div>
          <div class="kpi-meta"><span class="kpi-delta up">↑ 8.2%</span><span class="kpi-delta-label">vs last month</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Avg days in stage</div>
          <div class="kpi-value">18</div>
          <div class="kpi-meta"><span class="kpi-delta up">↓ 3</span><span class="kpi-delta-label">vs last month</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Win rate (90d)</div>
          <div class="kpi-value">34.2<span class="kpi-value-suffix">%</span></div>
          <div class="kpi-meta"><span class="kpi-delta down">↓ 1.8pt</span><span class="kpi-delta-label">peer avg: 37.1%</span></div>
        </div>
      </div>

      <div class="d360-strip">
        <div class="d360-strip-mark"><div class="d360-strip-mark-inner"></div></div>
        <div class="d360-strip-text">
          <div class="d360-strip-eyebrow">Powered by Data 360</div>
          <div class="d360-strip-title">Pipeline scores combine lead intent, cross-carrier shopping signals, and behavioral propensity into a single deal score.</div>
          <div class="d360-strip-sub">Each deal is scored in real time from 6 signal sources — higher scores close 2.6× faster on average.</div>
        </div>
        <div class="d360-strip-stats">
          <div><div class="d360-strip-stat-num">6</div><div class="d360-strip-stat-label">Sources</div></div>
          <div><div class="d360-strip-stat-num">12</div><div class="d360-strip-stat-label">Scored</div></div>
          <div><div class="d360-strip-stat-num">live</div><div class="d360-strip-stat-label">Updated</div></div>
        </div>
      </div>

      <%
        const allDeals = [].concat(...Object.values(stages));
        const atRiskCount = allDeals.filter(d => d.is_at_risk).length;
        const wonCount = (stages.won || []).length;
      %>
      <div data-filter-scope>
      <div class="tabs">
        <div class="tab active" data-filter="all">All deals <span class="tab-count"><%= allDeals.length %></span></div>
        <div class="tab" data-filter="all">This week <span class="tab-count">4</span></div>
        <div class="tab" data-filter="all">At risk <span class="tab-count"><%= atRiskCount %></span></div>
        <div class="tab" data-filter="all">Won (MTD) <span class="tab-count"><%= wonCount %></span></div>
      </div>

      <div class="pipeline-layout">

        <div class="pipeline-board">

          <%
            const stageMeta = [
              { key: 'prospect', label: 'Prospect' },
              { key: 'quoted',   label: 'Quoted' },
              { key: 'proposal', label: 'Proposal' },
              { key: 'negotiation', label: 'Negotiation' },
              { key: 'won',      label: 'Won' },
            ];
          %>

          <% stageMeta.forEach(sm => { %>
            <% const deals = stages[sm.key] || []; %>
            <% const colTotal = deals.reduce((s, d) => s + d.premium, 0); %>
            <div class="pipeline-col<%= sm.key === 'won' ? ' won' : '' %>">
              <div class="pipeline-col-header">
                <div class="pipeline-col-header-top">
                  <span class="pipeline-col-name"><%= sm.label %></span>
                  <span class="pipeline-col-count"><%= deals.length %></span>
                </div>
                <div class="pipeline-col-total">$<%= colTotal.toLocaleString() %>/yr<%= sm.key === 'won' ? ' · April' : '' %></div>
              </div>

              <% deals.forEach(d => { %>
                <a class="pipeline-card<%= d.is_at_risk ? ' at-risk' : '' %><%= d.is_won ? ' won' : '' %>" href="/customers/<%= d.slug %>">
                  <div class="pipeline-card-top">
                    <span class="pipeline-card-name"><%= d.customer_name %></span>
                    <span class="pipeline-card-age"><%= d.age_label %></span>
                  </div>
                  <div class="pipeline-card-detail"><%= d.detail %></div>
                  <div class="pipeline-card-footer">
                    <span class="pipeline-card-line <%= d.line_type %>"><%= d.line_type.charAt(0).toUpperCase() + d.line_type.slice(1) %></span>
                    <div class="pipeline-card-right">
                      <span class="pipeline-card-premium">$<%= d.premium.toLocaleString() %>/yr</span>
                      <span class="deal-score <%= d.deal_score >= 75 ? 'high' : d.deal_score >= 65 ? 'med' : 'low' %>"><%= d.deal_score %></span>
                    </div>
                  </div>
                  <% if (d.is_at_risk) { %><div class="at-risk-flag"><%= d.at_risk_label %></div><% } %>
                  <% if (d.is_won) { %><div class="won-flag"><%= d.won_label %></div><% } %>
                </a>
              <% }) %>
            </div>
          <% }) %>

        </div>

        <!-- PIPELINE INTELLIGENCE SIDEBAR -->
        <div class="pipeline-sidebar">

          <div class="panel">
            <div class="panel-header">
              <div>
                <span class="panel-title">Pipeline intelligence</span>
              </div>
              <span class="d360-pill">Data 360</span>
            </div>

            <div class="intel-item">
              <div class="intel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Martinez fleet deal</strong> has 76% close probability — similar deals close 2.3× faster after a site visit.</div>
                <div class="intel-meta">Propensity model · updated today</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>4 dormant life leads</strong> re-engaged this week from Agent 360 next-best-action. 2 have responded — Patel scheduling call today.</div>
                <div class="intel-meta">Agentforce action · 3 days ago</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon warn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Chen investment property</strong> stalled 8 days — competing Allstate quote detected via cross-carrier shopping signal. Consider a re-quote with multi-policy discount.</div>
                <div class="intel-meta">Shopping signal · detected April 24</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Park homeowners</strong> closing May 8 — property data shows 2,400 sq ft, built 2018, good condition. Pre-filled quote ready for review.</div>
                <div class="intel-meta">Property data · MLS + public records</div>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">
              <span class="panel-title">Stage velocity</span>
              <span class="d360-pill">Tableau Semantics</span>
            </div>
            <div style="padding: 14px 20px;">
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Prospect → Quoted</span><span class="benchmark-percentile">4.2d avg</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 85%;"></div></div>
                <div class="benchmark-meta"><span>You: 4.2d</span><span>Peers: 6.8d</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Quoted → Proposal</span><span class="benchmark-percentile">7.1d avg</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 72%;"></div></div>
                <div class="benchmark-meta"><span>You: 7.1d</span><span>Peers: 9.4d</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Proposal → Negotiation</span><span class="benchmark-percentile middle">11.3d avg</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill middle" style="width: 55%;"></div></div>
                <div class="benchmark-meta"><span>You: 11.3d</span><span>Peers: 8.9d</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0; border-bottom: none;">
                <div class="benchmark-head"><span class="benchmark-label">Negotiation → Close</span><span class="benchmark-percentile">6.4d avg</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 78%;"></div></div>
                <div class="benchmark-meta"><span>You: 6.4d</span><span>Peers: 8.1d</span></div>
              </div>
            </div>
          </div>

        </div>

      </div>
      </div>

      <div class="pipeline-summary">
        <div class="pipeline-summary-item"><span class="pipeline-summary-dot green"></span> 7 deals score 75+</div>
        <div class="pipeline-summary-item"><span class="pipeline-summary-dot amber"></span> 4 deals score 50–74</div>
        <div class="pipeline-summary-item"><span class="pipeline-summary-dot red"></span> 1 deal at risk</div>
      </div>

      <div class="content-footer">
        <div>Keystone Enterprise · Build 4.2.118</div>
        <div>SOC 2 Type II · Last sync 9:42 AM CT</div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
