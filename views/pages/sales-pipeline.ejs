                <span class="pipeline-col-count">4</span>
              </div>
              <div class="pipeline-col-total">$8,910/yr</div>
            </div>

            <a class="pipeline-card" href="/quote/new">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Patel family</span>
                <span class="pipeline-card-age">12d</span>
              </div>
              <div class="pipeline-card-detail">Term life cross-sell · $750K 20-year · client requested afternoon call</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line life">Life</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$1,180/yr</span>
                  <span class="deal-score high">81</span>
                </div>
              </div>
            </a>

            <a class="pipeline-card" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Crestline Bakery</span>
                <span class="pipeline-card-age">8d</span>
              </div>
              <div class="pipeline-card-detail">Cyber liability add-on · new TX product · existing BOP client</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line commercial">Commercial</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$4,200/yr</span>
                  <span class="deal-score med">74</span>
                </div>
              </div>
            </a>

            <a class="pipeline-card" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Henderson, T.</span>
                <span class="pipeline-card-age">5d</span>
              </div>
              <div class="pipeline-card-detail">Teen driver add · parent is existing auto policyholder · good driver discount eligible</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line auto">Auto</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$1,640/yr</span>
                  <span class="deal-score med">65</span>
                </div>
              </div>
            </a>

            <a class="pipeline-card" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Park, J.</span>
                <span class="pipeline-card-age">4d</span>
              </div>
              <div class="pipeline-card-detail">Renters → homeowners conversion · closing on property May 8</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line home">Home</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$1,890/yr</span>
                  <span class="deal-score high">78</span>
                </div>
              </div>
            </a>
          </div>

          <!-- PROPOSAL -->
          <div class="pipeline-col">
            <div class="pipeline-col-header">
              <div class="pipeline-col-header-top">
                <span class="pipeline-col-name">Proposal</span>
                <span class="pipeline-col-count">3</span>
              </div>
              <div class="pipeline-col-total">$30,880/yr</div>
