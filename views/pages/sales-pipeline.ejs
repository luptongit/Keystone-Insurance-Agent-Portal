                  <span class="pipeline-card-premium">$2,100/yr</span>
                  <span class="deal-score med">71</span>
                </div>
              </div>
            </a>
          </div>

          <!-- NEGOTIATION -->
          <div class="pipeline-col">
            <div class="pipeline-col-header">
              <div class="pipeline-col-header-top">
                <span class="pipeline-col-name">Negotiation</span>
                <span class="pipeline-col-count">2</span>
