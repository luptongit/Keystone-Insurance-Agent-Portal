                <span class="pipeline-card-age">14d</span>
              </div>
              <div class="pipeline-card-detail">Commercial GL + workers comp · 22 employees · fleet of 8 vehicles</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line commercial">Commercial</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$28,400/yr</span>
                  <span class="deal-score high">83</span>
                </div>
              </div>
            </a>

            <a class="pipeline-card" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Donovan, M.</span>
                <span class="pipeline-card-age">7d</span>
              </div>
              <div class="pipeline-card-detail">Umbrella upsell $1M → $2M · triggered by new boat purchase</div>
              <div class="pipeline-card-footer">
                <span class="pipeline-card-line umbrella">Umbrella</span>
                <div class="pipeline-card-right">
                  <span class="pipeline-card-premium">$380/yr</span>
                  <span class="deal-score high">88</span>
                </div>
              </div>
            </a>

            <a class="pipeline-card" href="/customers">
              <div class="pipeline-card-top">
                <span class="pipeline-card-name">Yamamoto, K.</span>
                <span class="pipeline-card-age">9d</span>
              </div>
