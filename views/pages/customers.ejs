<%- include('../partials/head', { pageCSS: 'customers' }) %>
<div class="app">
  <%- include('../partials/sidebar') %>

  <main class="main">
    <%- include('../partials/topbar', {
      breadcrumb: [
        { label: 'Customers' }
      ],
      topbarActions: `
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
          Filter
        </button>
        <button class="btn btn-primary">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>
          Add customer
        </button>
      `
    }) %>

    <div class="content">

      <div class="page-header">
        <div>
          <div class="greeting-eyebrow">Portfolio · April 2026</div>
          <h1 class="greeting-title">Your <em>customers</em></h1>
          <div class="greeting-sub">184 households · $2.14M total premium · <%= alerts.length %> need attention this week.</div>
        </div>
      </div>

      <div class="kpi-row cols-4">
        <div class="kpi">
          <div class="kpi-label">Total households</div>
          <div class="kpi-value">184</div>
          <div class="kpi-meta"><span class="kpi-delta up">↑ 3</span><span class="kpi-delta-label">new this month</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-d360-flag"><span class="d360-pill">D360</span></div>
          <div class="kpi-label">Needs attention</div>
          <div class="kpi-value"><%= alerts.length %></div>
          <div class="kpi-meta"><span class="kpi-delta-label">at-risk, claims, or overdue</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Avg lines per HH</div>
          <div class="kpi-value">1.56</div>
          <div class="kpi-meta"><span class="kpi-delta-label">target: 2.0+</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Avg lifetime value</div>
          <div class="kpi-value">$18.4<span class="kpi-value-suffix">K</span></div>
          <div class="kpi-meta"><span class="kpi-delta up">↑ 8%</span><span class="kpi-delta-label">YoY</span></div>
        </div>
      </div>

      <!-- NEEDS ATTENTION — highlight cards -->
      <div class="cust-attention-header">
        <div class="cust-attention-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          Needs attention
        </div>
        <div class="cust-attention-sub">Customers with open actions, at-risk signals, or time-sensitive items</div>
      </div>

      <div class="cust-attention-grid">
        <% alerts.forEach(alert => { %>
          <a class="cust-card<%= alert.is_urgent ? ' urgent' : '' %>" href="/customers/<%= alert.slug %>">
            <div class="cust-card-top">
              <div class="cust-card-avatar"><%= alert.initials %></div>
              <div>
                <div class="cust-card-name"><%= alert.name %></div>
                <div class="cust-card-meta"><%= alert.meta %></div>
              </div>
              <span class="cust-card-flag <%= alert.flag_type %>"><%= alert.flag_type === 'at-risk' ? 'At risk' : alert.flag_type.charAt(0).toUpperCase() + alert.flag_type.slice(1) %></span>
            </div>
            <div class="cust-card-signals">
              <% alert.signals.forEach(sig => { %>
                <div class="cust-card-signal<%= sig.is_warn ? ' warn' : '' %>"><%= sig.signal_text %></div>
              <% }) %>
            </div>
            <div class="cust-card-footer">
              <% alert.lines.forEach(line => { %>
                <span class="cust-card-badge <%= line %>"><%= line.charAt(0).toUpperCase() + line.slice(1) %></span>
              <% }) %>
              <span class="cust-card-action"><%= alert.action_text %></span>
            </div>
          </a>
        <% }) %>
      </div>

      <!-- FULL CUSTOMER LIST -->
      <div data-filter-scope>
      <div class="tabs" style="margin-top: 28px;">
        <div class="tab active" data-filter="all">All customers <span class="tab-count">184</span></div>
        <div class="tab" data-filter="personal">Personal <span class="tab-count">142</span></div>
        <div class="tab" data-filter="commercial">Commercial <span class="tab-count">32</span></div>
        <div class="tab" data-filter="recent">Recently active <span class="tab-count">18</span></div>
      </div>

      <div class="list-search">
        <svg class="list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        <input class="list-search-input" placeholder="Search customers..." data-search-scope=".cust-table" />
      </div>

      <div class="cust-layout">

        <div class="cust-table">

          <div class="cust-table-header">
            <span>Customer</span>
            <span>Lines</span>
            <span>Total premium</span>
            <span>Policies</span>
            <span>Tenure</span>
            <span>Retention</span>
            <span>Signals</span>
            <span></span>
          </div>

          <%
            const tableGroups = [
              { key: 'top_accounts', label: 'Top accounts', sub: 'by annual premium' },
              { key: 'personal', label: 'Personal lines', sub: 'recently active' },
            ];
          %>

          <% tableGroups.forEach(g => { %>
            <% const rows = groups[g.key] || []; %>
            <% if (rows.length) { %>
              <div class="cust-group" data-filter-group>
                <div class="cust-group-label"><%= g.label %> <span class="cust-group-count"><%= g.sub %></span></div>

                <% rows.forEach(cust => { %>
                  <a class="cust-row" href="/customers/<%= cust.slug %>" data-filter-value="<%= cust.lines.includes('commercial') ? 'commercial' : 'personal' %><%= g.key === 'top_accounts' ? ' recent' : '' %>" data-search-text="<%= cust.name %> <%= cust.detail %>">
                    <div class="cust-row-name">
                      <div class="cust-row-avatar<%= cust.avatar_style ? ' ' + cust.avatar_style : '' %>"><%= cust.initials %></div>
                      <div>
                        <div class="cust-row-customer"><%= cust.name %></div>
                        <div class="cust-row-detail"><%= cust.detail %></div>
                      </div>
                    </div>
                    <div>
                      <% cust.lines.forEach(line => { %>
                        <span class="cust-line <%= line %>"><%= line.charAt(0).toUpperCase() + line.slice(1) %></span>
                      <% }) %>
                    </div>
                    <div class="cust-row-premium">$<%= cust.premium.toLocaleString() %>/yr</div>
                    <div class="cust-row-num"><%= cust.policy_count %></div>
                    <div class="cust-row-num"><%= cust.tenure_display %></div>
                    <div>
                      <% if (cust.retention_score != null) { %>
                        <span class="retention-score <%= cust.retention_score >= 80 ? 'high' : cust.retention_score >= 70 ? 'med' : 'low' %>"><%= cust.retention_score %></span>
                      <% } %>
                    </div>
                    <div class="cust-row-signals">
                      <% cust.signals.forEach(dot => { %>
                        <span class="cust-signal-dot <%= dot.color %>" title="<%= dot.tooltip %>"></span>
                      <% }) %>
                    </div>
                    <div class="cust-row-action">
                      <button class="btn<%= cust.slug === 'ramirez-household' ? ' btn-primary' : '' %>"><%= cust.slug === 'ramirez-household' ? 'View 360' : 'View' %></button>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } %>
          <% }) %>

        </div>

        <!-- CUSTOMER INTELLIGENCE SIDEBAR -->
        <div class="cust-sidebar">

          <div class="panel">
            <div class="panel-header">
              <span class="panel-title">Portfolio health</span>
              <span class="d360-pill">Tableau Semantics</span>
            </div>
            <div style="padding: 14px 20px;">
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Healthy (85+)</span><span class="benchmark-percentile">142 HH</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 100%;"></div></div>
                <div class="benchmark-meta"><span>77% of book</span><span>$1.62M premium</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Monitor (65–84)</span><span class="benchmark-percentile middle">28 HH</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill middle" style="width: 20%;"></div></div>
                <div class="benchmark-meta"><span>15% of book</span><span>$380K premium</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0; border-bottom: none;">
                <div class="benchmark-head"><span class="benchmark-label">At risk (<65)</span><span class="benchmark-percentile" style="color: var(--red);">14 HH</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 10%;background:var(--red);"></div></div>
                <div class="benchmark-meta"><span>8% of book</span><span>$140K premium</span></div>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">
              <div><span class="panel-title">Customer intelligence</span></div>
              <span class="d360-pill">Data 360</span>
            </div>

            <div class="intel-item">
              <div class="intel-icon warn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>3 accounts are at-risk</strong> this week: Ramirez (competing quote), Kim (claims + shopping), and Blackwood (Nationwide signal). Combined premium at risk: $13,260/yr.</div>
                <div class="intel-meta">Retention model · real-time scoring</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Reeves household onboarded</strong> smoothly — auto-pay enrolled, ID cards generated, first bill paid. Referral credit applied to Donovan account.</div>
                <div class="intel-meta">New client health check · 7 days post-bind</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>68 single-line households</strong> have cross-sell scores above 70. Prioritize the 22 with active life events — they convert at 3.2× the baseline rate.</div>
                <div class="intel-meta">Cross-sell model · book-level analysis</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Park closing on home May 8.</strong> Homeowners quote is pre-filled from MLS data. Bind before closing to capture the premium — lender requires proof of insurance.</div>
                <div class="intel-meta">Life event · time-sensitive</div>
              </div>
            </div>
          </div>

        </div>

      </div>
      </div>

      <div class="content-footer">
        <div>Keystone Enterprise · Build 4.2.118</div>
        <div>SOC 2 Type II · Last sync 9:42 AM CT</div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
