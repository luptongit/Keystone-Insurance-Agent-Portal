<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Keystone — Sign in</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --keystone-blue: #0C447C;
    --granite: #2C2C2A;
    --limestone: #F1EFE8;
    --bronze: #BA7517;
    --text-muted: #6B6A65;
    --border: rgba(44, 44, 42, 0.12);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    height: 100%;
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--granite);
    background: var(--limestone);
    -webkit-font-smoothing: antialiased;
  }
  .layout { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; }
  .canvas {
    position: relative;
    background: var(--keystone-blue);
    color: var(--limestone);
    padding: 48px 56px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }
  .canvas::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .brand-row { display: flex; align-items: center; gap: 14px; position: relative; }
  .brand-mark { width: 32px; height: 32px; flex-shrink: 0; }
  .brand-name { font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; font-weight: 400; letter-spacing: -0.3px; }
  .hero { position: relative; z-index: 1; }
  .hero-arch { margin-bottom: 48px; opacity: 0.95; }
  .hero-headline {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 52px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    margin-bottom: 24px; max-width: 480px;
  }
  .hero-headline em { font-style: italic; font-weight: 400; }
  .hero-sub { font-size: 15px; line-height: 1.7; color: rgba(241, 239, 232, 0.75); max-width: 420px; }
  .canvas-footer {
    position: relative; z-index: 1;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: rgba(241, 239, 232, 0.55);
    letter-spacing: 0.5px; text-transform: uppercase;
  }
  .canvas-footer-line { flex: 1; height: 1px; background: rgba(241, 239, 232, 0.15); margin: 0 20px; }

  .form-side {
    background: var(--limestone);
    display: flex; align-items: center; justify-content: center;
    padding: 48px; position: relative;
  }
  .form-card { width: 100%; max-width: 380px; }
  .form-eyebrow {
    font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--bronze); margin-bottom: 16px; font-weight: 500;
  }
  .form-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 36px; font-weight: 400; line-height: 1.15; letter-spacing: -0.5px;
    margin-bottom: 8px;
  }
  .form-subtitle { font-size: 14px; color: var(--text-muted); margin-bottom: 36px; }
  .field { margin-bottom: 18px; }
  .field-label { display: block; font-size: 12px; font-weight: 500; color: var(--granite); margin-bottom: 6px; letter-spacing: 0.2px; }
  .field-input {
    width: 100%; padding: 12px 14px;
    border: 1px solid var(--border); background: #fff;
    font-family: inherit; font-size: 14px; color: var(--granite);
    border-radius: 4px;
  }
  .field-input:focus { outline: none; border-color: var(--keystone-blue); box-shadow: 0 0 0 3px rgba(12, 68, 124, 0.1); }

  .field-row { display: flex; justify-content: space-between; align-items: center; margin: 4px 0 24px; font-size: 13px; }
  .checkbox-row { display: flex; align-items: center; gap: 8px; color: var(--text-muted); }
  .checkbox-row input { accent-color: var(--keystone-blue); }
  .link { color: var(--keystone-blue); text-decoration: none; font-weight: 500; }
  .link:hover { text-decoration: underline; }

  .btn-primary {
    width: 100%; padding: 13px;
    background: var(--keystone-blue); color: var(--limestone);
    border: none; border-radius: 4px;
    font-family: inherit; font-size: 14px; font-weight: 500; letter-spacing: 0.2px;
    cursor: pointer; transition: background 0.15s;
    text-decoration: none; display: block; text-align: center;
  }
  .btn-primary:hover { background: #0a3a6a; }

  .divider {
    display: flex; align-items: center; margin: 28px 0;
    color: var(--text-muted); font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
  }
  .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .divider span { padding: 0 14px; }

  .btn-sso {
    width: 100%; padding: 12px;
    background: #fff; color: var(--granite); border: 1px solid var(--border);
    border-radius: 4px; font-family: inherit; font-size: 13px; font-weight: 500;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn-sso:hover { border-color: var(--granite); background: #fafaf6; }

  .form-footer {
    margin-top: 40px; padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 12px; color: var(--text-muted); text-align: center;
  }
  .help-corner { position: absolute; top: 40px; right: 48px; font-size: 13px; color: var(--text-muted); }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    .canvas { display: none; }
  }
</style>
</head>
<body>
<div class="layout">
  <aside class="canvas">
    <div class="brand-row">
      <svg class="brand-mark" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,100 30,20 90,20 120,100" fill="#F1EFE8"/>
        <polygon points="30,20 60,20 60,100 0,100" fill="#D4D2CB"/>
      </svg>
      <span class="brand-name">Keystone</span>
    </div>

    <div class="hero">
      <svg class="hero-arch" width="120" height="60" viewBox="0 0 120 60" xmlns="http://www.w3.org/2000/svg">
        <path d="M 0 60 L 0 30 Q 0 0 60 0 Q 120 0 120 30 L 120 60" fill="none" stroke="#F1EFE8" stroke-width="1.5"/>
        <polygon points="48,7 72,7 84,32 36,32" fill="#F1EFE8"/>
      </svg>
      <h1 class="hero-headline">The center of your <em>distribution.</em></h1>
      <p class="hero-sub">One platform for quoting, servicing, claims, sales, and growth — built for the way modern agents actually work.</p>
    </div>

    <div class="canvas-footer">
      <span>Enterprise edition</span>
      <span class="canvas-footer-line"></span>
      <span>v 4.2</span>
    </div>
  </aside>

  <main class="form-side">
    <div class="help-corner">Need help? <a href="#" class="link">Contact support</a></div>
    <div class="form-card">
      <div class="form-eyebrow">Producer sign-in</div>
      <h2 class="form-title">Welcome back.</h2>
      <p class="form-subtitle">Sign in to your agency workspace.</p>

      <form action="/" method="get">
        <div class="field">
          <label class="field-label" for="agency">Agency code</label>
          <input class="field-input" type="text" id="agency" value="HARTFORD-NW-0814" />
        </div>
        <div class="field">
          <label class="field-label" for="email">Email or producer ID</label>
          <input class="field-input" type="text" id="email" placeholder="m.chen@harborlightagency.com" />
        </div>
        <div class="field">
          <label class="field-label" for="pw">Password</label>
          <input class="field-input" type="password" id="pw" placeholder="••••••••••" />
        </div>

        <div class="field-row">
          <label class="checkbox-row"><input type="checkbox" /> Remember this device</label>
          <a href="#" class="link">Forgot password?</a>
        </div>

        <button type="submit" class="btn-primary">Sign in to Keystone</button>

        <div class="divider"><span>Or</span></div>

        <a href="/" class="btn-sso">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Continue with carrier SSO
        </a>
      </form>

      <div class="form-footer">
        Protected by enterprise SSO. By signing in, you agree to the <a href="#" class="link">acceptable use policy</a>.
      </div>
    </div>
  </main>
</div>
</body>
</html>
