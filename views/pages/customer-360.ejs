        <div class="tab active">Overview</div>
        <div class="tab">Policies <span class="tab-count">5</span></div>
        <div class="tab">Claims <span class="tab-count">2</span></div>
        <div class="tab">Billing</div>
        <div class="tab">Documents <span class="tab-count">28</span></div>
        <div class="tab">Notes <span class="tab-count">14</span></div>
      </div>

      <!-- GRID -->
      <div class="grid-360">

        <div class="col-stack">

          <!-- POLICIES -->
          <div class="panel">
