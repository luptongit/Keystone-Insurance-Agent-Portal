              <div class="event policy">
                <div class="event-time">Aug 2024</div>
                <div class="event-content">
                  <div class="event-title">Endorsement — added 2022 Honda CR-V</div>
                  <div class="event-detail">Replaced 2014 Honda Pilot · premium impact +$340/yr</div>
                  <div class="event-attribution">Maya Chen · self-service</div>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="col-stack">

          <div class="panel">
            <div class="panel-header">
              <span class="panel-title">Retention outlook</span>
              <span class="d360-pill">Data 360 prediction</span>
            </div>
            <div class="ret-meter">
              <div class="ret-score-row">
                <div class="ret-score-circle"><span class="ret-score-num">84</span></div>
