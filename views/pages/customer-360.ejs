        <div class="d360-hero-stats">
          <div><div class="d360-hero-stat-num">9</div><div class="d360-hero-stat-label">Sources</div></div>
          <div><div class="d360-hero-stat-num">247</div><div class="d360-hero-stat-label">Attributes</div></div>
          <div><div class="d360-hero-stat-num">&lt;2s</div><div class="d360-hero-stat-label">Refresh</div></div>
        </div>
      </div>

