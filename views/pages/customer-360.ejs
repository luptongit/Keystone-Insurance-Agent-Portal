<%
  const { customer: c, policies: pols, members, events, factors, opportunities } = profile;
  const iconSvg = {
    auto: '<path d="M3 13l2-7h14l2 7M5 13h14M5 13v5a1 1 0 001 1h2a1 1 0 001-1v-1M15 18v-1M15 18a1 1 0 001 1h2a1 1 0 001-1v-5"/>',
    home: '<path d="M3 12l9-9 9 9M5 10v10h14V10"/>',
    umbrella: '<path d="M12 2v2M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10H2zM12 12v8a2 2 0 11-4 0"/>',
    life: '<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>',
    commercial: '<path d="M3 21h18M3 7l9-4 9 4M5 7v14M19 7v14M9 21v-4h6v4M9 11h0M15 11h0"/>',
  };
%>
<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar') %>

  <main class="main">
    <%- include('../partials/topbar', {
      breadcrumb: [
        { label: 'Customers', href: '/customers' },
        { label: c.name }
      ],
      topbarActions: `
        <button class="icon-btn" title="More">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
        </button>
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          Message
        </button>
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          Call
        </button>
        <a class="btn btn-primary" href="/quote/new">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg>
          New quote
        </a>
      `
    }) %>

    <div class="content">

      <!-- ENTITY HEADER -->
      <div class="entity-header">
        <div class="entity-avatar customer"><%= c.initials %></div>
        <div>
          <div class="entity-name-row">
            <h1 class="entity-name"><%= c.name %></h1>
            <% if (c.tier) { %><span class="badge gold"><%= c.tier %> tier</span><% } %>
            <span class="badge tenure"><%= c.tenure_display %>-year client</span>
          </div>
          <div class="entity-meta">
            <% if (c.location) { %>
            <span class="entity-meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <%= c.location %>
            </span>
            <% } %>
            <% if (c.member_count) { %>
            <span class="entity-meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0116 0v1"/></svg>
              <%= c.member_count %> household members
            </span>
            <% } %>
            <% if (c.client_since) { %>
            <span class="entity-meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              Client since <%= c.client_since %>
            </span>
            <% } %>
          </div>
        </div>
        <div class="header-stats">
          <div><div class="header-stat-label">Total premium</div><div class="header-stat-value">$<%= pols.reduce((s, p) => s + p.premium, 0).toLocaleString() %></div><div class="header-stat-sub">annualized</div></div>
          <div><div class="header-stat-label">Active policies</div><div class="header-stat-value"><%= pols.length %></div><div class="header-stat-sub">across <%= [...new Set(pols.map(p => p.line_type))].length %> lines</div></div>
          <% if (c.lifetime_value) { %><div><div class="header-stat-label">Lifetime value</div><div class="header-stat-value"><%= c.lifetime_value %></div><div class="header-stat-sub"><%= c.tenure_display %> cumulative</div></div><% } %>
        </div>
      </div>

      <!-- DATA 360 HERO -->
      <div class="d360-hero">
        <div class="d360-hero-mark"><div class="d360-hero-mark-inner"></div></div>
        <div class="d360-hero-text">
          <div class="d360-hero-eyebrow">Powered by Data 360</div>
          <div class="d360-hero-title">This household profile is unified in real time across 9 connected systems.</div>
          <div class="d360-hero-sub">Policy admin, billing, claims, marketing, telematics, and 4 third-party data sources — harmonized into one identity-resolved profile via zero-copy federation.</div>
        </div>
        <div class="d360-hero-stats">
          <div><div class="d360-hero-stat-num">9</div><div class="d360-hero-stat-label">Sources</div></div>
          <div><div class="d360-hero-stat-num">247</div><div class="d360-hero-stat-label">Attributes</div></div>
          <div><div class="d360-hero-stat-num">&lt;2s</div><div class="d360-hero-stat-label">Refresh</div></div>
        </div>
      </div>

      <!-- TABS -->
      <div class="tabs">
        <div class="tab active">Overview</div>
        <div class="tab">Policies <span class="tab-count"><%= pols.length %></span></div>
        <div class="tab">Claims <span class="tab-count">2</span></div>
        <div class="tab">Billing</div>
        <div class="tab">Documents <span class="tab-count">28</span></div>
        <div class="tab">Notes <span class="tab-count">14</span></div>
      </div>

      <!-- GRID -->
      <div class="grid-360">

        <div class="col-stack">

          <!-- POLICIES -->
          <div class="panel">
            <div class="panel-header">
              <div>
                <span class="panel-title">Active policies</span>
                <span class="panel-title-meta"><%= pols.length %> policies · <%= [...new Set(pols.map(p => p.line_type))].join(', ') %></span>
              </div>
              <a class="panel-link" href="/policies">View all →</a>
            </div>

            <% pols.forEach(pol => { %>
              <div class="policy-row">
                <div class="policy-icon <%= pol.line_type %>">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><%- iconSvg[pol.line_type] || iconSvg.auto %></svg>
                </div>
                <div>
                  <div class="policy-title"><%= pol.title %></div>
                  <div class="policy-sub"><%= pol.subtitle %></div>
                </div>
                <div class="policy-num"><%= pol.policy_number %></div>
                <div>
                  <div class="policy-premium">$<%= pol.premium.toLocaleString() %>/yr</div>
                  <div class="policy-premium-sub"><%= pol.payment_freq %></div>
                </div>
                <span class="status <%= pol.status %>"><%= pol.status_label %></span>
              </div>
            <% }) %>
          </div>

          <!-- HOUSEHOLD -->
          <% if (members.length) { %>
          <div class="panel">
            <div class="panel-header">
              <div>
                <span class="panel-title">Household</span>
                <span class="panel-title-meta"><%= members.length %> members</span>
              </div>
              <a class="panel-link" href="#">Manage →</a>
            </div>
            <div class="household-grid">
              <% members.forEach(m => { %>
                <div class="member">
                  <div class="member-avatar <%= m.avatar_class %>"><%= m.initials %></div>
                  <div>
                    <div class="member-name"><%= m.name %></div>
                    <div class="member-relationship"><%= m.relationship %></div>
                    <div class="member-detail"><%= m.detail %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- TIMELINE -->
          <% if (events.length) { %>
          <div class="panel">
            <div class="panel-header">
              <div>
                <span class="panel-title">Activity timeline</span>
                <span class="panel-title-meta">unified across systems</span>
              </div>
              <span class="d360-pill">Data 360 unified</span>
            </div>
            <div class="timeline">
              <div class="timeline-filter">
                <span class="filter-pill active">All</span>
                <span class="filter-pill">Policies</span>
                <span class="filter-pill">Claims</span>
                <span class="filter-pill">Payments</span>
                <span class="filter-pill">Notes</span>
                <span class="filter-pill">Contact</span>
              </div>

              <% events.forEach(ev => { %>
                <div class="event <%= ev.event_type %>">
                  <div class="event-time"><%= ev.event_time %></div>
                  <div class="event-content">
                    <div class="event-title"><%= ev.title %></div>
                    <div class="event-detail"><%= ev.detail %></div>
                    <div class="event-attribution"><%= ev.attribution %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          <% } %>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="col-stack">

          <% if (factors.length) { %>
          <div class="panel">
            <div class="panel-header">
              <span class="panel-title">Retention outlook</span>
              <span class="d360-pill">Data 360 prediction</span>
            </div>
            <div class="ret-meter">
              <div class="ret-score-row">
                <div class="ret-score-circle"><span class="ret-score-num"><%= c.retention_detail_score || c.retention_score || '—' %></span></div>
                <div>
                  <div class="ret-label">Likelihood to retain</div>
                  <div class="ret-status"><%= (c.retention_detail_score || c.retention_score || 0) >= 80 ? 'Low risk' : (c.retention_detail_score || c.retention_score || 0) >= 65 ? 'Moderate risk' : 'High risk' %></div>
                </div>
              </div>
              <div class="ret-factors">
                <% factors.forEach(f => { %>
                  <div class="ret-factor">
                    <span class="ret-factor-label"><%= f.label %></span>
                    <span class="ret-factor-val<%= f.sentiment === 'pos' ? ' pos' : '' %>"<%= f.sentiment === 'neg' ? ' style="color: var(--red);"' : '' %>><%= f.value %></span>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <% if (opportunities.length) { %>
          <div class="panel">
            <div class="panel-header">
              <div><span class="panel-title">Opportunities</span></div>
              <span class="d360-pill">Data 360 + Agentforce</span>
            </div>

            <% opportunities.forEach(opp => { %>
              <div class="opp-card">
                <div class="opp-row">
                  <div class="opp-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><%- opp.icon_svg %></svg>
                  </div>
                  <div class="opp-title"><%= opp.title %></div>
                  <span class="opp-confidence"><%= opp.confidence %>%</span>
                </div>
                <div class="opp-desc"><%= opp.description %></div>
                <div class="opp-meta">
                  <span><%= opp.meta_left %></span>
                  <span><%= opp.meta_right %></span>
                </div>
              </div>
            <% }) %>
          </div>
          <% } %>

          <div class="panel">
            <div class="panel-header"><span class="panel-title">Quick actions</span></div>
            <div class="qa-grid">
              <div class="qa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
                <span class="qa-label">Generate ID card</span>
              </div>
              <div class="qa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7"/></svg>
                <span class="qa-label">Endorsement</span>
              </div>
              <div class="qa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83"/></svg>
                <span class="qa-label">File FNOL</span>
              </div>
              <div class="qa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
                <span class="qa-label">Make payment</span>
              </div>
              <div class="qa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h6"/></svg>
                <span class="qa-label">Send dec page</span>
              </div>
              <div class="qa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 113 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                <span class="qa-label">Add note</span>
              </div>
            </div>
          </div>

          <% if (c.email || c.phone) { %>
          <div class="panel">
            <div class="panel-header"><span class="panel-title">Contact</span></div>
            <% if (c.email) { %><div class="info-row"><span class="info-label">Email</span><span class="info-val"><a href="#"><%= c.email %></a></span></div><% } %>
            <% if (c.phone) { %><div class="info-row"><span class="info-label">Mobile</span><span class="info-val"><%= c.phone %></span></div><% } %>
            <% if (c.preferred_contact) { %><div class="info-row"><span class="info-label">Preferred</span><span class="info-val"><%= c.preferred_contact %></span></div><% } %>
            <% if (c.language) { %><div class="info-row"><span class="info-label">Language</span><span class="info-val"><%= c.language %></span></div><% } %>
            <div class="info-row"><span class="info-label">Last contact</span><span class="info-val">2 days ago</span></div>
          </div>
          <% } %>

          <!-- DATA 360 INSIDE -->
          <div class="d360-inside">
            <div class="d360-inside-head">
              <div class="d360-inside-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12l9-9 9 9M5 10v10h14V10"/><circle cx="12" cy="14" r="2"/></svg>
              </div>
              <div class="d360-inside-title">Data 360 inside</div>
              <span class="d360-inside-meta">9 sources · live</span>
            </div>

            <div class="d360-source-row">
              <div><div class="d360-source-name">Policy admin (Guidewire)</div><div class="d360-source-detail">Coverage, drivers, vehicles, history</div></div>
              <div class="d360-source-attrs">82 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Billing system</div><div class="d360-source-detail">Payment history, autopay status</div></div>
              <div class="d360-source-attrs">31 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Claims platform</div><div class="d360-source-detail">Loss history, severity, fraud signals</div></div>
              <div class="d360-source-attrs">24 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Marketing engagement</div><div class="d360-source-detail">Email opens, web visits, NPS</div></div>
              <div class="d360-source-attrs">18 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Telematics (UBI program)</div><div class="d360-source-detail">Driving behavior, mileage, hard brakes</div></div>
              <div class="d360-source-attrs">42 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">MVR / CLUE / VIN</div><div class="d360-source-detail">Driving record, prior claims, vehicle</div></div>
              <div class="d360-source-attrs">28 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Property & public records</div><div class="d360-source-detail">Replacement cost, ownership, lifecycle</div></div>
              <div class="d360-source-attrs">15 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Cross-carrier shopping signals</div><div class="d360-source-detail">Quote-shopping, competing rate exposure</div></div>
              <div class="d360-source-attrs">7 attrs</div><div class="d360-source-status"></div>
            </div>
            <div class="d360-source-row">
              <div><div class="d360-source-name">Snowflake (zero-copy)</div><div class="d360-source-detail">Carrier data warehouse · federated</div></div>
              <div class="d360-source-attrs">∞ attrs</div><div class="d360-source-status"></div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </main>
</div>
<%- include('../partials/foot') %>
