                <div class="ret-factor"><span class="ret-factor-label">Claims history</span><span class="ret-factor-val pos">Clean</span></div>
                <div class="ret-factor"><span class="ret-factor-label">Tenure</span><span class="ret-factor-val pos">7 years</span></div>
                <div class="ret-factor"><span class="ret-factor-label">Renewal premium change</span><span class="ret-factor-val" style="color: var(--red);">+18.4%</span></div>
                <div class="ret-factor"><span class="ret-factor-label">Competing quote received</span><span class="ret-factor-val" style="color: var(--red);">Yes</span></div>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">
              <div><span class="panel-title">Opportunities</span></div>
              <span class="d360-pill">Data 360 + Agentforce</span>
            </div>

            <div class="opp-card">
              <div class="opp-row">
                <div class="opp-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 13l2-7h14l2 7M5 13h14M5 13v5a1 1 0 001 1h2a1 1 0 001-1v-1"/></svg>
                </div>
