                  <div class="event-attribution">Maya Chen · 9:14 AM</div>
                </div>
              </div>

              <div class="event policy">
                <div class="event-time">2 days ago</div>
                <div class="event-content">
                  <div class="event-title">Renewal package generated — auto + home</div>
                  <div class="event-detail">Renewal premiums calculated with +18.4% increase driven by territory loss trends and roof age (16yr).</div>
                  <div class="event-attribution">System · automated</div>
                </div>
              </div>

              <div class="event payment">
                <div class="event-time">Apr 14</div>
                <div class="event-content">
                  <div class="event-title">Payment received — $153.33</div>
                  <div class="event-detail">Auto policy monthly autopay · ACH from Wells Fargo ending 4421</div>
                  <div class="event-attribution">System · billing</div>
                </div>
              </div>

