              <div class="policy-num">POL-HO-441208</div>
              <div>
                <div class="policy-premium">$2,000/yr</div>
                <div class="policy-premium-sub">$500 deductible</div>
              </div>
              <span class="status renewal">Renews 5d</span>
            </div>

            <div class="policy-row">
              <div class="policy-icon umbrella">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2v2M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10H2zM12 12v8a2 2 0 11-4 0"/></svg>
              </div>
              <div>
                <div class="policy-title">Personal umbrella — $2M limit</div>
                <div class="policy-sub">Excess liability above auto and home · added July 2022</div>
              </div>
              <div class="policy-num">POL-UM-090714</div>
              <div>
                <div class="policy-premium">$340/yr</div>
                <div class="policy-premium-sub">annual pay</div>
              </div>
              <span class="status active">Active</span>
            </div>

            <div class="policy-row">
              <div class="policy-icon life">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              </div>
              <div>
                <div class="policy-title">Term life — Carlos Ramirez</div>
                <div class="policy-sub">$500K · 20-year term · issued 2021 · standard non-tobacco</div>
              </div>
              <div class="policy-num">POL-LF-220103</div>
              <div>
                <div class="policy-premium">$640/yr</div>
                <div class="policy-premium-sub">quarterly</div>
              </div>
              <span class="status active">Active</span>
            </div>

            <div class="policy-row">
              <div class="policy-icon life">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              </div>
              <div>
                <div class="policy-title">Term life — Elena Ramirez</div>
                <div class="policy-sub">$400K · 20-year term · issued 2021 · standard non-tobacco</div>
              </div>
              <div class="policy-num">POL-LF-220104</div>
              <div>
                <div class="policy-premium">$600/yr</div>
                <div class="policy-premium-sub">quarterly</div>
              </div>
              <span class="status active">Active</span>
            </div>
