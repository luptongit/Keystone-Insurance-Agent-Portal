              </div>
              <div>
                <div class="policy-title">Personal auto — 2 vehicles</div>
                <div class="policy-sub">2022 Honda CR-V · 2019 Toyota Camry · Carlos & Elena Ramirez</div>
              </div>
              <div class="policy-num">POL-AU-771422</div>
              <div>
                <div class="policy-premium">$1,840/yr</div>
                <div class="policy-premium-sub">monthly autopay</div>
              </div>
              <span class="status renewal">Renews 5d</span>
            </div>

            <div class="policy-row">
              <div class="policy-icon home">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg>
              </div>
              <div>
                <div class="policy-title">Homeowners — HO-3 standard</div>
                <div class="policy-sub">3,420 sqft · built 2008 · $485K dwelling · $50K personal property</div>
