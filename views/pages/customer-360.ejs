                <span>1 min flow</span>
              </div>
            </div>

            <div class="opp-card">
              <div class="opp-row">
                <div class="opp-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <div class="opp-title">529 college savings plan</div>
                <span class="opp-confidence">62%</span>
