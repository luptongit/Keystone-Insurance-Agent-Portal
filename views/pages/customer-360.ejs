              </div>
              <div class="member">
                <div class="member-avatar b">ER</div>
                <div>
                  <div class="member-name">Elena Ramirez</div>
                  <div class="member-relationship">Spouse · age 42</div>
                  <div class="member-detail">DL · Driver · Insured (life)</div>
                </div>
              </div>
              <div class="member">
                <div class="member-avatar c">SR</div>
                <div>
                  <div class="member-name">Sofia Ramirez</div>
                  <div class="member-relationship">Daughter · age 17</div>
                  <div class="member-detail">Permit · Eligible to add</div>
                </div>
              </div>
              <div class="member">
                <div class="member-avatar d">DR</div>
                <div>
                  <div class="member-name">Diego Ramirez</div>
                  <div class="member-relationship">Son · age 14</div>
                  <div class="member-detail">Dependent</div>
                </div>
              </div>
            </div>
          </div>

