<%
  const renewalGroups = [
    { key: 'this_week', label: 'This week', sub: '3 policies · $52,680/yr' },
    { key: 'next_2_weeks', label: 'Next 2 weeks', sub: '6 policies · $18,940/yr' },
    { key: '30_days', label: '30 days', sub: '8 policies · $22,580/yr' },
    { key: '60_days', label: '60 days', sub: '5 policies · $93,400/yr' },
  ];
%>
<%- include('../partials/head', { pageCSS: 'renewals' }) %>
<div class="app">
  <%- include('../partials/sidebar') %>

  <main class="main">
    <%- include('../partials/topbar', {
      breadcrumb: [
        { label: 'Service' },
        { label: 'Renewals' }
      ],
      topbarActions: `
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
          Filter
        </button>
        <button class="btn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          Export
        </button>
      `
    }) %>

    <div class="content">

      <div class="page-header">
        <div>
          <div class="greeting-eyebrow">Service · April 2026</div>
          <h1 class="greeting-title">Renewal <em>management</em></h1>
          <div class="greeting-sub">42 policies renewing in the next 60 days — $187K in annual premium at risk.</div>
        </div>
      </div>

      <div class="kpi-row cols-4">
        <div class="kpi">
          <div class="kpi-label">Renewing next 30d</div>
          <div class="kpi-value">23</div>
          <div class="kpi-meta"><span class="kpi-delta-label">$94.2K annual premium</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-d360-flag"><span class="d360-pill">D360</span></div>
          <div class="kpi-label">Retention rate (12mo)</div>
          <div class="kpi-value">88.2<span class="kpi-value-suffix">%</span></div>
          <div class="kpi-meta"><span class="kpi-delta down">↓ 2.8pt</span><span class="kpi-delta-label">peer avg: 91.0%</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-d360-flag"><span class="d360-pill">Predicted</span></div>
          <div class="kpi-label">At-risk renewals</div>
          <div class="kpi-value">5</div>
          <div class="kpi-meta"><span class="kpi-delta-label">flagged by retention model</span></div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Avg premium change</div>
          <div class="kpi-value">+6.8<span class="kpi-value-suffix">%</span></div>
          <div class="kpi-meta"><span class="kpi-delta down">↑ 2.1pt</span><span class="kpi-delta-label">vs last quarter</span></div>
        </div>
      </div>

      <div class="d360-strip">
        <div class="d360-strip-mark"><div class="d360-strip-mark-inner"></div></div>
        <div class="d360-strip-text">
          <div class="d360-strip-eyebrow">Powered by Data 360</div>
          <div class="d360-strip-title">Retention scoring combines payment behavior, shopping signals, premium sensitivity, and tenure into a single risk score.</div>
          <div class="d360-strip-sub">Each renewal is scored against 8 churn indicators — policies with scores below 70 renew at half the rate of those above 85.</div>
        </div>
        <div class="d360-strip-stats">
          <div><div class="d360-strip-stat-num">8</div><div class="d360-strip-stat-label">Signals</div></div>
          <div><div class="d360-strip-stat-num">42</div><div class="d360-strip-stat-label">Scored</div></div>
          <div><div class="d360-strip-stat-num">live</div><div class="d360-strip-stat-label">Updated</div></div>
        </div>
      </div>

      <div class="tabs">
        <div class="tab active">All renewals <span class="tab-count">42</span></div>
        <div class="tab">This week <span class="tab-count"><%= (groups.this_week || []).length %></span></div>
        <div class="tab">At risk <span class="tab-count">5</span></div>
        <div class="tab">Auto-renew <span class="tab-count">28</span></div>
        <div class="tab">Requires review <span class="tab-count">9</span></div>
      </div>

      <div class="renewals-layout">

        <div class="renewals-table">

          <div class="renewals-table-header">
            <span>Customer</span>
            <span>Policy</span>
            <span>Current</span>
            <span>Renewal</span>
            <span>Change</span>
            <span>Date</span>
            <span>Retention</span>
            <span>Status</span>
            <span></span>
          </div>

          <% renewalGroups.forEach(g => { %>
            <% const rows = groups[g.key] || []; %>
            <% if (rows.length) { %>
              <div class="renewals-group">
                <div class="renewals-group-label"><%= g.label %> <span class="renewals-group-count"><%= g.sub %></span></div>

                <% rows.forEach(row => { %>
                  <a class="renewal-row<%= row.is_at_risk ? ' at-risk' : '' %>" href="/customers/<%= row.slug %>">
                    <div class="renewal-row-name">
                      <div class="renewal-row-customer"><%= row.customer_name %></div>
                      <div class="renewal-row-detail"><%= row.detail %></div>
                    </div>
                    <div>
                      <% row.lines.forEach(line => { %>
                        <span class="rnw-line <%= line %>"><%= line.charAt(0).toUpperCase() + line.slice(1) %></span>
                      <% }) %>
                    </div>
                    <div class="renewal-row-premium">$<%= row.current_premium.toLocaleString() %>/yr</div>
                    <div class="renewal-row-premium">$<%= row.renewal_premium.toLocaleString() %>/yr</div>
                    <div class="renewal-row-change <%= row.change_dir %>"><%= row.change_dir === 'flat' ? '' : '+' %><%= Number(row.change_pct).toFixed(1) %>%</div>
                    <div class="renewal-row-date<%= row.date_urgency ? ' ' + row.date_urgency : '' %>"><%= row.renewal_date %></div>
                    <div><span class="retention-score <%= row.retention_score >= 80 ? 'high' : row.retention_score >= 70 ? 'med' : 'low' %>"><%= row.retention_score %></span></div>
                    <div><span class="renewal-status-badge <%= row.status %>"><%= row.status === 'at-risk' ? 'At risk' : row.status === 'auto-renew' ? 'Auto-renew' : row.status.charAt(0).toUpperCase() + row.status.slice(1) %></span></div>
                    <div class="renewal-row-action"><button class="btn"><%= row.status === 'auto-renew' ? 'View' : 'Review' %></button></div>
                  </a>
                <% }) %>
              </div>
            <% } %>
          <% }) %>

        </div>

        <!-- RETENTION INTELLIGENCE SIDEBAR -->
        <div class="renewals-sidebar">

          <div class="panel">
            <div class="panel-header">
              <div>
                <span class="panel-title">Retention intelligence</span>
              </div>
              <span class="d360-pill">Data 360</span>
            </div>

            <div class="intel-item">
              <div class="intel-icon warn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Ramirez household</strong> has a competing State Farm quote $660 below renewal premium. 7-year client with 5 policies — a bundle re-rate with loyalty discount would close the gap to $180.</div>
                <div class="intel-meta">Shopping signal · detected April 27</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon warn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Kim, S.</strong> retention score dropped 14 points after second claim. Progressive quote signal detected — consider proactive outreach before May 15 renewal.</div>
                <div class="intel-meta">Behavioral churn model · updated today</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>Blackwood Properties</strong> is shopping 3-property portfolio with Nationwide. Premium sensitivity modeling suggests a 4.2% rate hold on the package would retain — still profitable at 22% combined ratio margin.</div>
                <div class="intel-meta">Premium sensitivity model · 3 sources</div>
              </div>
            </div>

            <div class="intel-item">
              <div class="intel-icon success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
              </div>
              <div>
                <div class="intel-text"><strong>12 auto-renew policies</strong> have retention scores above 85 and require no intervention. Together they represent $28.4K in annual premium on stable trajectories.</div>
                <div class="intel-meta">Retention model · book-level summary</div>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panel-header">
              <span class="panel-title">Retention by line</span>
              <span class="d360-pill">Tableau Semantics</span>
            </div>
            <div style="padding: 14px 20px;">
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Personal auto</span><span class="benchmark-percentile">89.4%</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 89%;"></div></div>
                <div class="benchmark-meta"><span>You: 89.4%</span><span>Peers: 91.2%</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Homeowners</span><span class="benchmark-percentile">91.8%</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 92%;"></div></div>
                <div class="benchmark-meta"><span>You: 91.8%</span><span>Peers: 90.6%</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0;">
                <div class="benchmark-head"><span class="benchmark-label">Commercial</span><span class="benchmark-percentile middle">84.1%</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill middle" style="width: 84%;"></div></div>
                <div class="benchmark-meta"><span>You: 84.1%</span><span>Peers: 88.7%</span></div>
              </div>
              <div class="benchmark-row" style="padding: 8px 0; border-bottom: none;">
                <div class="benchmark-head"><span class="benchmark-label">Life & umbrella</span><span class="benchmark-percentile">96.2%</span></div>
                <div class="benchmark-bar"><div class="benchmark-fill" style="width: 96%;"></div></div>
                <div class="benchmark-meta"><span>You: 96.2%</span><span>Peers: 94.8%</span></div>
              </div>
            </div>
          </div>

        </div>

      </div>

      <div class="pipeline-summary">
        <div class="pipeline-summary-item"><span class="pipeline-summary-dot green"></span> 12 policies score 85+</div>
        <div class="pipeline-summary-item"><span class="pipeline-summary-dot amber"></span> 8 policies score 65–84</div>
        <div class="pipeline-summary-item"><span class="pipeline-summary-dot red"></span> 5 policies at risk</div>
      </div>

      <div class="content-footer">
        <div>Keystone Enterprise · Build 4.2.118</div>
        <div>SOC 2 Type II · Last sync 9:42 AM CT</div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
