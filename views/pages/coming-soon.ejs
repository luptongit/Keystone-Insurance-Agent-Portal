<%
const _notFound = locals.notFound || false;
%>
<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar') %>

  <main class="main">
    <%- include('../partials/topbar') %>

    <div class="coming-soon-wrap">
      <div class="coming-soon">
        <svg class="coming-soon-mark" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <polygon points="0,100 30,20 90,20 120,100" fill="#185FA5"/>
          <polygon points="30,20 60,20 60,100 0,100" fill="#0C447C"/>
        </svg>
        <% if (_notFound) { %>
          <div class="coming-soon-eyebrow">404 · Page not found</div>
          <h1 class="coming-soon-title">That route <em>doesn't exist</em>.</h1>
          <p class="coming-soon-text">The page you're looking for isn't part of this build. Use the sidebar to navigate, or head back home.</p>
        <% } else { %>
          <div class="coming-soon-eyebrow">In the demo backlog</div>
          <h1 class="coming-soon-title"><em><%= label %></em> — coming soon.</h1>
          <p class="coming-soon-text">This screen isn't built out yet in the demo. The five flagship flows — Home, Customer 360, Quote &amp; bind, Agent 360, and the Platform map — are fully wired and ready to walk through.</p>
        <% } %>
        <div class="coming-soon-actions">
          <a class="btn btn-primary" href="/">← Back to home</a>
          <a class="btn" href="/platform-map">Platform overview</a>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
