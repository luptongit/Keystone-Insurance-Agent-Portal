<%
// Sidebar nav data — single source of truth for nav structure.
// `key` matches the `activeNav` value passed by each page route.
const navSections = [
  {
    items: [
      { key: 'home',       label: 'Home',              href: '/',          icon: 'home' },
      { key: 'customers',  label: 'Customers',         href: '/customers', icon: 'user' },
      { key: 'book',       label: 'Book of business',  href: '/book-of-business', icon: 'rows' },
    ]
  },
  {
    label: 'Sell',
    items: [
      { key: 'quote',     label: 'New quote',      href: '/quote/new',     icon: 'search' },
      { key: 'pipeline',  label: 'Sales pipeline', href: '/sales-pipeline', icon: 'pipeline', badge: '12' },
      { key: 'leads',     label: 'Leads',          href: '/leads',          icon: 'clock' },
    ]
  },
  {
    label: 'Service',
    items: [
      { key: 'policies',     label: 'Policies',      href: '/policies',     icon: 'doc' },
      { key: 'endorsements', label: 'Endorsements',  href: '/endorsements', icon: 'chat' },
      { key: 'claims',       label: 'Claims (FNOL)', href: '/claims',       icon: 'star',  badge: '3' },
      { key: 'renewals',     label: 'Renewals',      href: '/renewals',     icon: 'cal' },
      { key: 'billing',      label: 'Billing',       href: '/billing',      icon: 'card' },
    ]
  },
  {
    label: 'Grow',
    items: [
      { key: 'agent360',    label: 'Agent 360',           href: '/agent-360',        icon: 'chart' },
      { key: 'marketing',   label: 'Marketing studio',    href: '/marketing-studio', icon: 'msg' },
      { key: 'commissions', label: 'Commissions',         href: '/commissions',      icon: 'dollar' },
    ]
  },
  {
    label: 'Resources',
    items: [
      { key: 'knowledge',    label: 'Knowledge base',     href: '/knowledge-base',  icon: 'book' },
      { key: 'training',     label: 'Training & licensing', href: '/training',       icon: 'check' },
      { key: 'underwriting', label: 'Underwriting hub',   href: '/underwriting-hub', icon: 'grid' },
    ]
  },
];

// Inline SVG icon library — small, neutral, no external font deps.
const icons = {
  home:     '<path d="M3 12l9-9 9 9M5 10v10h14V10"/>',
  user:     '<circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0116 0v1"/>',
  rows:     '<path d="M3 7h18M3 12h18M3 17h18"/>',
  search:   '<circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>',
  pipeline: '<path d="M12 2L4 7l8 5 8-5-8-5zM4 17l8 5 8-5M4 12l8 5 8-5"/>',
  clock:    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>',
  doc:      '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/>',
  chat:     '<path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>',
  star:     '<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>',
  cal:      '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
  card:     '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>',
  chart:    '<path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/>',
  msg:      '<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>',
  dollar:   '<path d="M12 2v20M5 9h14M5 15h14"/>',
  book:     '<path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2zM22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>',
  check:    '<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>',
  grid:     '<path d="M4 4h16v16H4z"/><path d="M4 9h16M9 4v16"/>',
};
%>
<aside class="sidebar">
  <a class="sidebar-brand" href="/">
    <svg class="sidebar-mark" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,100 30,20 90,20 120,100" fill="#F1EFE8"/>
      <polygon points="30,20 60,20 60,100 0,100" fill="#A8A6A0"/>
    </svg>
    <span class="sidebar-brand-name">Keystone</span>
  </a>

  <% navSections.forEach(section => { %>
    <div class="nav-section">
      <% if (section.label) { %>
        <div class="nav-section-label"><%= section.label %></div>
      <% } %>
      <% section.items.forEach(item => { %>
        <a class="nav-item <%= activeNav === item.key ? 'active' : '' %>" href="<%= item.href %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"><%- icons[item.icon] %></svg>
          <%= item.label %>
          <% if (item.badge) { %>
            <span class="nav-badge"><%= item.badge %></span>
          <% } %>
        </a>
      <% }) %>
    </div>
  <% }) %>

  <div class="d360-sidebar-strip">
    <div class="d360-sidebar-strip-dot"></div>
    <span class="d360-sidebar-strip-name">Data 360</span>
    <span class="d360-sidebar-strip-status">Live · 14 src</span>
  </div>

  <div class="sidebar-footer">
    <div class="avatar-sm"><%= user.initials %></div>
    <div class="user-info">
      <div class="user-name"><%= user.name %></div>
      <div class="user-role"><%= user.role %></div>
    </div>
  </div>
</aside>
