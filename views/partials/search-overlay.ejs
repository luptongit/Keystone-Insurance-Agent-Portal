<div class="search-overlay" id="searchOverlay">
  <div class="search-overlay-backdrop"></div>
  <div class="search-overlay-panel">
    <div class="search-overlay-input-wrap">
      <svg class="search-overlay-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input class="search-overlay-input" id="searchOverlayInput" placeholder="Search customers, policies, pipeline..." autocomplete="off" />
      <span class="search-overlay-esc">Esc</span>
    </div>
    <div class="search-overlay-results" id="searchOverlayResults">
      <div class="search-overlay-empty-state">
        <div class="search-empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        </div>
        <div class="search-empty-text">Search across your entire book</div>
        <div class="search-empty-sub">Customers, policies, pipeline deals</div>
      </div>
    </div>
    <div class="search-overlay-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
      <span><kbd>↵</kbd> Open</span>
      <span><kbd>Esc</kbd> Close</span>
    </div>
  </div>
</div>
